{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@visualizer/*": ["../visualizer-poc/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/remote/vj-remote-server.ts"]
}
