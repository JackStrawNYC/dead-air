{
  "name": "@dead-air/visualizer-poc",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "exports": {
    "./shaders/*": "./src/shaders/*.ts",
    "./utils/math": "./src/utils/math.ts",
    "./data/types": "./src/data/types.ts",
    "./scenes/scene-registry": "./src/scenes/scene-registry.ts"
  },
  "scripts": {
    "analyze": ".venv/bin/python scripts/analyze.py",
    "analyze:docker": "docker run --rm -v $(pwd)/public/audio:/data/audio:ro -v $(pwd)/data:/data/output -v $(pwd)/../../data/stems:/data/stems:ro dead-air-analyze analyze",
    "analyze:docker:show": "docker run --rm -v $(pwd)/public/audio:/data/audio:ro -v $(pwd)/data:/data/output -v $(pwd)/data:/data/setlist:ro -v $(pwd)/../../data/stems:/data/stems:ro dead-air-analyze analyze-show",
    "analyze:docker:show:resume": "docker run --rm -v $(pwd)/public/audio:/data/audio:ro -v $(pwd)/data:/data/output -v $(pwd)/data:/data/setlist:ro -v $(pwd)/../../data/stems:/data/stems:ro dead-air-analyze analyze-show --resume",
    "analyze:show": ".venv/bin/python scripts/analyze_show.py",
    "analyze:show:resume": ".venv/bin/python scripts/analyze_show.py --resume",
    "docker:build": "docker build -t dead-air-analyze -f ../../docker/Dockerfile.analyze ../..",
    "docker:build:gpu": "docker build -t dead-air-gpu -f ../../docker/Dockerfile.gpu ../..",
    "docker:build:all": "pnpm docker:build && pnpm docker:build:gpu",
    "docker:health": "docker run --rm dead-air-analyze healthcheck",
    "docker:health:gpu": "docker run --rm dead-air-gpu healthcheck",
    "stems:docker": "docker run --rm -i -v $(pwd)/public/audio:/data/audio:ro -v $(pwd)/../../data/stems:/data/stems -v $(pwd)/../../data/cache:/data/cache dead-air-gpu separate-stems",
    "lyrics:docker": "docker run --rm -i -v $(pwd)/public/audio:/data/audio:ro -v $(pwd)/../../data/lyrics:/data/lyrics -v $(pwd)/../../data/cache:/data/cache dead-air-gpu align-lyrics",
    "studio": "npx remotion studio src/entry.ts --props=data/morning-dew-analysis.json",
    "studio:song": "npx remotion studio src/entry.ts",
    "render:morning-dew": "npx remotion render src/entry.ts MorningDew out/morning-dew.mp4 --props=data/morning-dew-analysis.json --gl=angle",
    "render:clip": "npx remotion render src/entry.ts MorningDew out/test-clip.mp4 --props=data/morning-dew-analysis.json --frames=0-900 --gl=angle",
    "render:climax": "npx remotion render src/entry.ts MorningDew out/test-climax.mp4 --props=data/morning-dew-analysis.json --frames=23200-24100 --gl=angle",
    "render:show": "npx tsx scripts/render-show.ts",
    "render:show:resume": "npx tsx scripts/render-show.ts --resume",
    "validate": "npx tsx scripts/validate-pipeline.ts",
    "validate:verbose": "npx tsx scripts/validate-pipeline.ts --verbose",
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/fiber": "^8.18.0",
    "@remotion/cli": "4.0.242",
    "@remotion/google-fonts": "4.0.242",
    "@remotion/media-utils": "4.0.242",
    "@remotion/three": "4.0.242",
    "dotenv": "^16.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.242",
    "replicate": "^1.0.0",
    "three": "^0.183.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/three": "^0.183.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
